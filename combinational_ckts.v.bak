module tb_logicgates;
 
    reg a, b;
    wire y0, y1, y2, y3, y4, y5, y6;
 
    logicgates uut (
        .a(a), .b(b),
        .y0(y0), .y1(y1), .y2(y2), .y3(y3),
        .y4(y4), .y5(y5), .y6(y6)
    );
 
    initial begin
        a = 0; b = 0; #10;
        a = 0; b = 1; #10;
        a = 1; b = 0; #10;
        a = 1; b = 1; #10;
        $finish;
    end
 
endmodule
 
